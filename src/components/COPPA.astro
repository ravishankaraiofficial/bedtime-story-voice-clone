<div class="coppa-shield">
  <div class="coppa-icon">
    <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
  </div>
  <div class="coppa-text">
    <strong>Zero-Retention Privacy (COPPA Compliant)</strong>
    <p>Your audio and your child's voice are processed strictly in-transit. No recordings are ever saved, stored, or used for AI training.</p>
  </div>
</div>

<style>
  .coppa-shield {
    display: flex;
    align-items: flex-start;
    gap: 1rem;
    padding: 1rem;
    margin: 2rem 0;
    background: rgba(223, 146, 83, 0.05);
    border: 1px solid rgba(223, 146, 83, 0.2);
    border-radius: 12px;
    color: var(--text-secondary);
  }
  
  .coppa-icon {
    color: #df9253;
    flex-shrink: 0;
    margin-top: 2px;
  }
  
  .coppa-text strong {
    display: block;
    color: var(--text-primary);
    font-size: 0.9rem;
    margin-bottom: 0.25rem;
  }
  
  .coppa-text p {
    font-size: 0.8rem;
    margin: 0;
    line-height: 1.4;
  }
</style>
