---
// ReelGenerator.astro - Viral Media Export Mock
---
<reel-generator>
  <button id="exportReelBtn" class="reel-button">
    <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
      <polygon points="23 7 16 12 23 17 23 7"></polygon>
      <rect x="1" y="5" width="15" height="14" rx="2" ry="2"></rect>
    </svg>
    Export TikTok / Shorts Reel
  </button>
  <div id="reelStatus" class="reel-status"></div>
</reel-generator>

<style>
  .reel-button {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    background: linear-gradient(135deg, #df9253, #c77430);
    color: #111;
    border: none;
    padding: 0.75rem 1.25rem;
    border-radius: 8px;
    font-size: 0.9rem;
    font-weight: bold;
    cursor: pointer;
    transition: transform 0.2s, opacity 0.2s;
  }
  .reel-button:hover {
    transform: scale(1.02);
  }
  .reel-button:disabled {
    opacity: 0.6;
    cursor: not-allowed;
    transform: none;
  }
  .reel-status {
    font-size: 0.8rem;
    color: #df9253;
    margin-top: 0.5rem;
    font-style: italic;
  }
</style>

<script>
  class ReelGenerator extends HTMLElement {
    constructor() {
      super();
      this.btn = this.querySelector('#exportReelBtn');
      this.statusText = this.querySelector('#exportStatus');

      if (this.btn) {
        this.btn.addEventListener('click', () => this.generateMockReel());
      }
    }

    async generateMockReel() {
      this.btn.disabled = true;
      if(this.statusText) this.statusText.textContent = "Packaging SVG, Audio, and Subtitles for cloud processing...";
      
      console.log("[ReelGenerator] Triggering Cloud Export Workflow for 60s Vertical MP4.");
      
      // Mock processing delay for cloud task
      await new Promise(r => setTimeout(r, 2500));
      
      if(this.statusText) this.statusText.textContent = "Reel generated! Downloading mock mp4...";
      console.log("[ReelGenerator] Mock mp4 download triggered.");
      
      setTimeout(() => {
        if(this.statusText) this.statusText.textContent = "";
        this.btn.disabled = false;
      }, 3000);
    }
  }
  customElements.define('reel-generator', ReelGenerator);
</script>
