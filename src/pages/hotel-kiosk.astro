---
// Hotel Kiosk Mode - B2B Luxury Deployment
---
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1, maximum-scale=1, user-scalable=0" />
  <title>Kiosk - Bedtime Story App</title>
  <style>
    body {
      background-color: #05070d;
      color: #e5e3db;
      font-family: 'Inter', sans-serif;
      margin: 0;
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      height: 100vh;
      overflow: hidden;
    }
    .kiosk-container {
      text-align: center;
      max-width: 800px;
      padding: 2rem;
      background: rgba(255, 255, 255, 0.02);
      border-radius: 16px;
      box-shadow: 0 8px 32px rgba(0, 0, 0, 0.4);
      border: 1px solid rgba(223, 146, 83, 0.1);
    }
    .brand-title {
      font-size: 2.5rem;
      color: #df9253;
      margin-bottom: 0.5rem;
    }
    .reset-btn {
      margin-top: 2rem;
      background: #df9253;
      color: #05070d;
      border: none;
      padding: 1rem 2rem;
      font-size: 1.2rem;
      border-radius: 8px;
      cursor: pointer;
      font-weight: bold;
    }
    .config-panel {
      margin-top: 2rem;
      display: flex;
      flex-direction: column;
      gap: 1rem;
      text-align: left;
    }
    .config-panel input {
      padding: 0.75rem;
      background: rgba(255, 255, 255, 0.05);
      border: 1px solid rgba(223, 146, 83, 0.2);
      color: #fff;
      border-radius: 6px;
    }
  </style>
</head>
<body>
  <div class="kiosk-container">
    <h1 class="brand-title">The Grand Resort Wellness Kiosk</h1>
    <p>Welcome. Tap below to prepare this device for a new guest.</p>
    
    <div class="config-panel">
      <label>Resort Mascot / Theme:</label>
      <input type="text" id="mascotInput" value="The Grand Resort Sleepy Bear" />
      <label>Local Landmark:</label>
      <input type="text" id="landmarkInput" value="The Emerald Mountains" />
    </div>

    <button class="reset-btn" id="resetRoomBtn">Reset Room & Start Story Mode</button>
  </div>

  <script>
    document.getElementById('resetRoomBtn').addEventListener('click', () => {
      // 1. One-tap Reset
      localStorage.clear();
      sessionStorage.clear();
      console.log("[Kiosk] Room reset complete. Cleared all local state.");
      
      // 2. Inject Dynamic Variables for Gemini
      const mascot = document.getElementById('mascotInput').value;
      const landmark = document.getElementById('landmarkInput').value;
      localStorage.setItem('kiosk_mascot', mascot);
      localStorage.setItem('kiosk_landmark', landmark);
      
      // 3. Redirect to Main App
      window.location.href = '/?mode=kiosk';
    });
  </script>
</body>
</html>
